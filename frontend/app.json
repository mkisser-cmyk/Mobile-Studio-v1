{
  "expo": {
    "name": "RailStream Studio",
    "slug": "railstream-studio",
    "version": "2.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "railstream-studio",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.railstream.studio",
      "buildNumber": "211",
      "infoPlist": {
        "NSCameraUsageDescription": "View live camera feeds from sites",
        "NSLocationWhenInUseUsageDescription": "Show nearby sites on map"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1c1c1c"
      },
      "edgeToEdgeEnabled": true,
      "package": "net.railstream.studio",
      "versionCode": 211
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "RailStream Studio",
      "shortName": "RailStream"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "developer": "Orange Cat Studios",
      "copyright": "© 2025 RailStream. All rights reserved."
    }
  }
}
